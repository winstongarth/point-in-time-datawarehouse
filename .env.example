# Copy this file to .env and fill in real values. .env is gitignored.

# Postgres DSN used directly by psycopg and (with the driver made explicit) by
# Alembic. The default below matches docker-compose.yml for local dev.
PDW_DATABASE_URL=postgresql://pdw:pdw@localhost:5433/pdw

# SEC EDGAR requires a descriptive User-Agent with a real, working contact
# email (see CLAUDE.md 4.1). Never commit a real email — this is a placeholder.
PDW_EDGAR_CONTACT_EMAIL=your-name@example.com

PDW_LOG_LEVEL=INFO
PDW_ENVIRONMENT=development
